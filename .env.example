# PostgreSQL (Docker service name: db)
POSTGRES_DB=ccms_db
POSTGRES_USER=ccms_user
POSTGRES_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# SCDMS integration (Submission & Decision Portal)
# CDP_* names are historical; must match SCDMS CMS_CALLBACK_SECRET
CDP_BASE_URL=http://localhost:8080
CDP_CALLBACK_SECRET=change-me-shared-with-scdms

# Frontend (optional — Docker Compose sets these)
# VITE_API_URL=/api/v1
# VITE_PROXY_TARGET=http://backend:8000
